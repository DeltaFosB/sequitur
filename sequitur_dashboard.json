      "title": "Sequitur Core Processing - Total Ingress Invariants",
      "type": "timeseries",
      "datasource": { "type": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki" },
          "editorMode": "code",
          "expr": "sum by (app) (last_over_time({app=\"sequitur_engine\"} | json | unwrap total_orders [1m]))",
