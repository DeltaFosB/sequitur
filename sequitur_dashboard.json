          "queryType": "range"
        },
        {
          "datasource": { "type": "loki" },
          "editorMode": "code",
          "expr": "sum by (app) (last_over_time({app=\"sequitur_engine\"} | json | unwrap total_trades [1m]))",
          "legendFormat": "Total Matching Trades",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "short"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Sub-Microsecond Latency Profiles (Go -> C++ IPC Boundary)",
      "type": "timeseries",
      "datasource": { "type": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki" },
          "editorMode": "code",
          "expr": "avg by (app) (avg_over_time({app=\"sequitur_engine\"} | json | unwrap p50_latency_ns [1m]))",
