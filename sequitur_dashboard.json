        {
          "datasource": { "type": "loki" },
          "editorMode": "code",
          "expr": "avg by (app) (avg_over_time({app=\"sequitur_engine\"} | json | unwrap p99_latency_ns [1m]))",
          "legendFormat": "P99 Tail Latency",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter" },
          "unit": "ns"
        }
